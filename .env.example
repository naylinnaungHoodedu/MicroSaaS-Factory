# Core security
ADMIN_ACCESS_KEY=change-me
MICROSAAS_FACTORY_ENCRYPTION_KEY=change-me
INTERNAL_AUTOMATION_KEY=change-me
MICROSAAS_FACTORY_APP_URL=http://localhost:3000
# Set to 1 only after the public edge is confirmed to issue a permanent HTTP -> HTTPS redirect.
MICROSAAS_FACTORY_LONG_HSTS=0
# Commercial rollout order:
# 1. Keep at least one visible public plan live. The repo seeds "growth" when no
#    public plan would otherwise exist, but production should still verify the
#    live Growth lane intentionally.
# 2. Keep MICROSAAS_FACTORY_LONG_HSTS=0 until verify-public-edge confirms HTTP 301.
# 3. Configure both NEXT_PUBLIC_FIREBASE_* and FIREBASE_SERVICE_ACCOUNT_* until
#    /api/healthz reports selfServeReady=true and guidance.repoControlledIssues
#    no longer includes self-serve activation work.
# 4. Configure STRIPE_PLATFORM_SECRET_KEY,
#    STRIPE_PLATFORM_WEBHOOK_SECRET, STRIPE_PLATFORM_PRICE_MAP_JSON, and
#    MICROSAAS_FACTORY_APP_URL together until /api/healthz reports
#    checkoutReady=true and guidance.repoControlledIssues no longer includes
#    Stripe checkout work.
# 5. Deploy, confirm /api/healthz, then run verify-public-edge with
#    -ExpectLaunchReady before leaving the full self-serve posture on.
# 6. Only after those checks pass should the final public launch posture remain on:
#    platformBillingEnabled=true, publicSignupEnabled=true,
#    selfServeProvisioningEnabled=true, checkoutEnabled=true.

# Storage backend
# Use "local" for development and "firestore" for production.
# Set FIRESTORE_PROJECT_ID explicitly in production.
MICROSAAS_FACTORY_DB_BACKEND=local
MICROSAAS_FACTORY_LOCAL_DB_FILE=.local/microsaas-factory-db.json
MICROSAAS_FACTORY_FIRESTORE_COLLECTION=microsaasFactoryState
FIRESTORE_PROJECT_ID=
FIRESTORE_DATABASE_ID=
FIRESTORE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CLOUD_PROJECT=

# Firebase client
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# Firebase admin
# Canonical production names:
FIREBASE_SERVICE_ACCOUNT_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_CLIENT_EMAIL=
FIREBASE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Backward-compatible aliases:
FIREBASE_ADMIN_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# GitHub app + platform webhooks
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Required before checkoutEnabled=true can stay on in production.
STRIPE_PLATFORM_SECRET_KEY=
STRIPE_PLATFORM_WEBHOOK_SECRET=
STRIPE_PLATFORM_PRICE_MAP_JSON={"growth":{"monthly":"price_monthly_123","annual":"price_annual_123"}}

# Vertex AI / Gemini
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_SERVICE_ACCOUNT_JSON=
VERTEX_SERVICE_ACCOUNT_JSON_BASE64=
