{
  "name": "microsaas-factory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "e2e:server": "node scripts/e2e-web-server.mjs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.provider=v8",
    "audit:deps": "npm audit --audit-level=high",
    "sbom:generate": "npm sbom --sbom-format=cyclonedx --sbom-type=application > sbom.cdx.json",
    "audit:container": "docker scout cves --exit-code --only-severity critical,high local://microsaas-factory-local:latest",
    "audit:all": "npm run audit:deps && npm run test:coverage && npm run sbom:generate && npm run audit:container",
    "test:e2e": "npm run build && playwright test",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.5.0",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "fast-xml-parser": "5.7.1"
  }
}
